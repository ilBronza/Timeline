{
    "name": "ilbronza/timeline",
    "description": "Gantt / timeline visualization components (vis-timeline) for Laravel and IlBronza packages",
    "license": "MIT",
    "authors": [
        {
            "name": "Davide Bronzini",
            "email": "davide@sistema.srl",
            "homepage": "https://www.sistema.srl"
        }
    ],
    "homepage": "https://github.com/ilbronza/timeline",
    "keywords": ["Laravel", "Timeline", "Gantt", "vis-timeline"],
